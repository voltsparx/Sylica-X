# Ignore self-assessment and source intel text/markdown files
intel-sources/*.txt
intel-sources/*.md

# Keep folder structure if needed
!intel-sources/.gitkeep

# Python cache and virtual environments
__pycache__/
*.py[cod]
*.pyo
*.pyd
.mypy_cache/
.ruff_cache/
.pytest_cache/
.venv/
venv/
env/

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Runtime output artifacts (keep folder structure only)
output/**
!output/.gitkeep
!output/data/
!output/data/.gitkeep
!output/html/
!output/html/.gitkeep
!output/cli/
!output/cli/.gitkeep
!output/logs/
!output/logs/.gitkeep

# Local test scratch
.tmp/
.tmp_test/
.tmp-tests/
pytest-cache-files-*/