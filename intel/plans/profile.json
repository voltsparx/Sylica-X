{
  "workflow": "profile",
  "features": [
    "async_engine",
    "retry_backoff",
    "rate_limit",
    "plugin_module_system",
    "signal_fusion_lane",
    "exports_reporting",
    "test_coverage"
  ],
  "capability_plan": [
    {
      "feature": "async_engine",
      "priority": "harden",
      "action": "Increase non-blocking collectors and connector reuse."
    },
    {
      "feature": "retry_backoff",
      "priority": "harden",
      "action": "Tune retry windows, jitter, and transient-error handling."
    },
    {
      "feature": "rate_limit",
      "priority": "harden",
      "action": "Calibrate concurrency with adaptive workload backpressure."
    },
    {
      "feature": "plugin_module_system",
      "priority": "harden",
      "action": "Strengthen module contracts and discovery validation."
    },
    {
      "feature": "signal_fusion_lane",
      "priority": "harden",
      "action": "Expand connector orchestration to leverage high-value multi-source collectors safely."
    },
    {
      "feature": "exports_reporting",
      "priority": "harden",
      "action": "Expand analyst outputs with richer graph/report artifacts."
    },
    {
      "feature": "test_coverage",
      "priority": "harden",
      "action": "Close regression gaps around failure paths and adapters."
    }
  ],
  "target_modules": [
    "core/engines/async_engine.py",
    "core/collect/scanner.py",
    "core/collect/domain_intel.py",
    "core/collect/http_resilience.py",
    "core/engines/thread_engine.py",
    "core/engines/parallel_engine.py",
    "core/extensions/plugin_manager.py",
    "core/extensions/signal_forge.py",
    "core/extensions/signal_sieve.py",
    "core/collect/source_fusion.py",
    "plugins/signal_fusion_core.py",
    "filters/signal_lane_fusion.py",
    "core/artifacts/reporting.py",
    "core/artifacts/output.py",
    "core/artifacts/html_report.py",
    "tests/"
  ]
}